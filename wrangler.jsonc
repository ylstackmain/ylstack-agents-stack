{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ylstack-agents-stack",
  "main": "dist/server/server.js",
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS",
  },
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ylstack-agents-stack",
      "database_id": "17c1fe96-b2f1-4dd5-ac6a-6a0da4db2be8",
      "migrations_dir": "migrations",
    },
  ],
  "r2_buckets": [
    {
      "binding": "WORKSPACE_BUCKET",
      "bucket_name": "ylstack-agents-stack-workspace",
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "DownyAgent",
        "class_name": "DownyAgent",
      },
      {
        "name": "ChildAgent",
        "class_name": "ChildAgent",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["DownyAgent", "ChildAgent"],
    },
  ],
  "ai": {
    "binding": "AI",
  },
  "vars": {
    "MODEL_ID": "@cf/moonshotai/kimi-k2.6",
    "TEAM_DOMAIN": "",
    "POLICY_AUD": "",
    "EXA_API_KEY": "",
  },
  "observability": {
    "enabled": true,
  },
  "upload_source_maps": true,
}
